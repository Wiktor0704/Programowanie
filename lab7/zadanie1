<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Dzielenie liczb</title>
    <style>
        body {
            font-family: Arial;
            margin: 40px;
        }
        input, button {
            margin: 5px;
            padding: 5px;
        }
        #wynik {
            margin-top: 15px;
            font-weight: bold;
        }
    </style>
</head>
<body>

<h2>Dzielenie dwóch liczb</h2>

<input type="text" id="liczba1" placeholder="Podaj pierwszą liczbę">
<input type="text" id="liczba2" placeholder="Podaj drugą liczbę">
<button onclick="dziel()">Oblicz</button>

<div id="wynik"></div>

<script>
function dziel() {
    const wynikDiv = document.getElementById("wynik");

    try {
        let a = document.getElementById("liczba1").value;
        let b = document.getElementById("liczba2").value;

        // Zamiana na liczby
        a = parseFloat(a);
        b = parseFloat(b);

        // Sprawdzenie poprawności danych
        if (isNaN(a) || isNaN(b)) {
            throw new Error("Wprowadź poprawne liczby!");
        }

        if (b === 0) {
            throw new Error("Nie można dzielić przez zero!");
        }

        let wynik = a / b;
        wynikDiv.innerText = "Wynik: " + wynik;

    } catch (error) {
        wynikDiv.innerText = "Błąd: " + error.message;
    }
}
</script>

</body>
</html>
